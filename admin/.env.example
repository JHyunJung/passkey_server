# Build-time only. Vite inlines VITE_* into the bundle, so never put secrets here.
VITE_API_BASE_URL=https://api.passkey.example.com

# Sentry — optional. Leave blank to disable error reporting entirely (no-op init).
VITE_SENTRY_DSN=
VITE_RELEASE=passkey-admin@0.1.0
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=0.5
